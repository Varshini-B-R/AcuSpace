{
  "expo": {
    "name": "AcuSpace",
    "slug": "acu-space",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "acu-space",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.varshini.acu-space"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#FAFAF5"
      },
      "permissions": [],
      "package": "com.varshini.acuspace",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png",
      "splash": {
        "backgroundColor": "#FAFAF5"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aebaa801-9843-4c4f-93e9-b4b13658fea8"
      }
    },
    "owner": "varshini_b_r"
  }
}
